{
  "manifest_version": 3,
  "name": "PolarAgent Browser Use",
  "version": "1.0.0",
  "description": "Browser control extension for PolarAgent",
  "permissions": [
    "cookies",
    "tabs",
    "tabGroups",
    "activeTab",
    "debugger",
    "scripting",
    "alarms",
    "storage",
    "declarativeNetRequest",
    "management",
    "contentSettings"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PolarAgent Browser Use",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
